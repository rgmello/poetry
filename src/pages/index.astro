---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const poems: CollectionEntry<"poems">[] = await getCollection("poems");
---

<Layout title="Meus Poemas">
  <header class="mb-16 text-center">
    <h1 class="text-4xl md:text-5xl font-light tracking-wide mb-4">
      Coleção de Poemas
    </h1>
    <p class="text-slate-500 italic">Um santuário para as palavras</p>
  </header>

  <div class="grid gap-8 md:grid-cols-2">
    {
      poems.map((poem) => (
        <a
          href={`/poems/${poem.id}`}
          class="group block p-8 bg-white border border-slate-200 rounded-sm hover:border-slate-400 transition-colors duration-300"
        >
          <h2 class="text-2xl mb-2 group-hover:text-slate-600 transition-colors">
            {poem.data.title}
          </h2>
          <p class="text-slate-500 italic mb-4">por {poem.data.author}</p>

          <div class="flex gap-2">
            {poem.data.tags?.map((tag: string) => (
              <span class="text-xs uppercase tracking-wider text-slate-400">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))
    }
  </div>
</Layout>
