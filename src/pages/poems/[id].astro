---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const poemEntries: CollectionEntry<"poems">[] = await getCollection("poems");

  return poemEntries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"poems">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <nav class="mb-12">
    <a
      href="/"
      class="flex items-center text-slate-400 hover:text-slate-800 transition-colors uppercase tracking-widest text-sm w-fit"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mr-2"
      >
        <path d="m12 19-7-7 7-7"></path>
        <path d="M19 12H5"></path>
      </svg>
      Voltar
    </a>
  </nav>

  <article class="mx-auto">
    <header class="mb-12 text-center border-b border-slate-200 pb-8">
      <h1 class="text-3xl md:text-4xl font-normal mb-2">{entry.data.title}</h1>
      <p class="text-xl text-slate-500 italic">por {entry.data.author}</p>
    </header>

    <div class="prose prose-slate prose-lg mx-auto max-w-none font-serif">
      <Content />
    </div>
  </article>
</Layout>
